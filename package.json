{
  "name": "squire",
  "version": "0.1.0",
  "description": "Quality-aware LLM proxy with automatic model escalation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "litellm",
    "llm-proxy",
    "validation",
    "quality-routing",
    "roundtable",
    "ai-gateway"
  ],
  "author": "Derek Mackley <derek.mackley@hotmail.com>",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.3",
    "prom-client": "^15.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.2",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
